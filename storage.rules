rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    /** True when Firestore says this user is admin (requires Storage↔Firestore rules link in GCP IAM). */
    function isAdminViaFirestore() {
      let p = /databases/(default)/documents/users/$(request.auth.uid);
      return request.auth != null
        && firestore.exists(p)
        && firestore.get(p).data.role == 'admin';
    }

    /**
     * Shop asset uploads from the admin panel.
     * 1) Custom claim storageAdmin (set via scripts/set-storage-admin-claim.mjs) — evaluated first,
     *    so uploads work even if cross-service Firestore reads from Storage rules are blocked.
     * 2) Otherwise Firestore users/{uid}.role == 'admin'
     */
    function canUploadShopAssets() {
      return request.auth != null
        && (
          request.auth.token.storageAdmin == true
          || isAdminViaFirestore()
        );
    }

    // Shop GLBs: nested paths shop-models/room/foo.glb
    match /shop-models/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if canUploadShopAssets()
        && request.resource.size < 100 * 1024 * 1024;
    }
    match /skin-textures/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if canUploadShopAssets()
        && request.resource.size < 15 * 1024 * 1024;
    }

    // Quest proof attachments
    // Students upload only to their own uid folder; teachers & admins can read all.
    match /questProofs/{uid}/{questId}/{filename} {
      allow read: if request.auth != null && (
        request.auth.uid == uid ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'teacher' ||
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 20 * 1024 * 1024;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
  }
}
