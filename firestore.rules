rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuth() {
      return request.auth != null;
    }

    function userDoc() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return isAuth()
        && exists(userDoc())
        && get(userDoc()).data.role == 'admin';
    }

    function isTeacher() {
      return isAuth()
        && exists(userDoc())
        && get(userDoc()).data.role == 'teacher';
    }

    /**
     * Нагорода → updateQuestProgress(учень): вчитель має читати/писати dailyQuests учня.
     * classIds у вчителя може бути порожнім або відсутнім (старі записи) — тоді не блокуємо.
     */
    function teacherMayTouchStudentDailyQuest(ownerUid) {
      return isTeacher()
        && exists(/databases/$(database)/documents/users/$(ownerUid))
        && get(/databases/$(database)/documents/users/$(ownerUid)).data.role == 'student'
        && (
          !('classIds' in get(userDoc()).data)
          || !(get(userDoc()).data.classIds is list)
          || get(userDoc()).data.classIds.size() == 0
          || !('classId' in get(/databases/$(database)/documents/users/$(ownerUid)).data)
          || !(get(/databases/$(database)/documents/users/$(ownerUid)).data.classId is string)
          || get(userDoc()).data.classIds.hasAny([
            get(/databases/$(database)/documents/users/$(ownerUid)).data.classId
          ])
        );
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    /** Учень з цим uid і classId входить до одного з класів вчителя (перегляд журналу / транзакцій). */
    function studentInTeachersClasses(studentUid) {
      return isTeacher()
        && exists(/databases/$(database)/documents/users/$(studentUid))
        && get(/databases/$(database)/documents/users/$(studentUid)).data.role == 'student'
        && 'classId' in get(/databases/$(database)/documents/users/$(studentUid)).data
        && get(/databases/$(database)/documents/users/$(studentUid)).data.classId is string
        && 'classIds' in get(userDoc()).data
        && get(userDoc()).data.classIds is list
        && get(userDoc()).data.classIds.hasAny([
          get(/databases/$(database)/documents/users/$(studentUid)).data.classId
        ]);
    }

    function teacherMayReadTransactionForClassJournal() {
      return isTeacher()
        && (
          (resource.data.fromUid is string && studentInTeachersClasses(resource.data.fromUid))
          || (resource.data.toUid is string && studentInTeachersClasses(resource.data.toUid))
        );
    }

    /** Same class (supports classId and/or classIds on either profile). */
    function studentUsersShareAClassByData(a, b) {
      return (
        ('classId' in a) && a.classId is string
        && ('classId' in b) && b.classId is string
        && a.classId == b.classId
      ) || (
        ('classIds' in a) && a.classIds is list
        && ('classId' in b) && b.classId is string
        && a.classIds.hasAny([b.classId])
      ) || (
        ('classId' in a) && a.classId is string
        && ('classIds' in b) && b.classIds is list
        && b.classIds.hasAny([a.classId])
      ) || (
        ('classIds' in a) && a.classIds is list
        && ('classIds' in b) && b.classIds is list
        && a.classIds.hasAny(b.classIds)
      );
    }

    /** Authenticated student may read a tx if they share a class with that user (classmate / same-room feed). */
    function viewerStudentSharesClassWithUser(otherUid) {
      return isAuth()
        && exists(userDoc())
        && get(userDoc()).data.role == 'student'
        && otherUid is string
        && exists(/databases/$(database)/documents/users/$(otherUid))
        && studentUsersShareAClassByData(
          get(userDoc()).data,
          get(/databases/$(database)/documents/users/$(otherUid)).data
        );
    }

    function studentMayReadTransactionForClassmateFeed() {
      return isAuth()
        && exists(userDoc())
        && get(userDoc()).data.role == 'student'
        && (
          (resource.data.fromUid is string && viewerStudentSharesClassWithUser(resource.data.fromUid))
          || (resource.data.toUid is string && viewerStudentSharesClassWithUser(resource.data.toUid))
        );
    }

    /** User doc exists and role is student (for tx party checks). */
    function userDocRoleIsStudent(uid) {
      return uid is string
        && exists(/databases/$(database)/documents/users/$(uid))
        && 'role' in get(/databases/$(database)/documents/users/$(uid)).data
        && get(/databases/$(database)/documents/users/$(uid)).data.role == 'student';
    }

    /**
     * Учень може читати транзакцію, якщо хоча б одна сторона — учень (журнал профілю / нарахування).
     * Запити в застосунку обмежені toUid/fromUid конкретного профілю — не відкриває довільний list по всій базі без індексу.
     */
    function studentMayReadTransactionInvolvingStudentParty() {
      return isAuth()
        && exists(userDoc())
        && get(userDoc()).data.role == 'student'
        && (
          (resource.data.fromUid is string && userDocRoleIsStudent(resource.data.fromUid))
          || (resource.data.toUid is string && userDocRoleIsStudent(resource.data.toUid))
        );
    }

    // Access codes — public read so unauthenticated users can look up their code before login
    match /accessCodes/{code} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users
    match /users/{uid} {
      allow read: if isAuth();
      // allow self-create so a manually bootstrapped account can write its own profile
      allow create: if isAdmin() || (isAuth() && request.auth.uid == uid);
      allow update: if isOwner(uid) || isAdmin() || isTeacher()
        // Trade execution writes coins/inventory (+counts)/xp for both parties atomically;
        // limit this broader permission to only those fields.
        || (isAuth() && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['coins', 'inventory', 'inventoryCounts', 'xp', 'level', 'avatar', 'tradesCompleted']));
      allow delete: if isAdmin();

      /**
       * Денний ліміт штрафів учня цим вчителем (id = {studentUid}_{yyyy-mm-dd}).
       * create — перший запис; update — накопичення totalFined (merge); лише власник підшляху (вчитель).
       */
      match /finesAppliedToday/{strikeId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) || isAdmin();
        allow update: if isOwner(uid) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // Classes
    match /classes/{classId} {
      allow read: if isAuth();
      allow create, update, delete: if isAdmin();
    }

    // Shop items — students may only decrease stock by exactly 1 (purchase / loot box).
    // Use affectedKeys + numeric equality so FieldValue.increment(-1) passes rules (changedKeys
    // / diff edge cases used to block valid decrements).
    match /items/{itemId} {
      allow read: if isAuth();
      allow create, delete: if isAdmin();
      allow update: if isAdmin()
        || (
          isAuth()
          && 'stock' in resource.data
          && resource.data.stock is number
          && resource.data.stock > 0
          && request.resource.data.stock is number
          && request.resource.data.stock == resource.data.stock - 1
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
        );
    }

    // Subjects
    match /subjects/{subjectId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Trade offers — no get() calls in read so query listeners work reliably
    match /tradeOffers/{offerId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow create: if isAuth()
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid
      );
      allow delete: if isAdmin()
        || (isAuth() && resource.data.fromUid == request.auth.uid);
    }

    // Transactions / award history (admin must list all for DevTools flush)
    match /transactions/{txId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.fromUid == request.auth.uid ||
        resource.data.toUid == request.auth.uid ||
        teacherMayReadTransactionForClassJournal() ||
        studentMayReadTransactionForClassmateFeed() ||
        studentMayReadTransactionInvolvingStudentParty()
      );
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // Achievements definitions
    match /achievements/{achId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Per-user daily quests — document IDs are "{uid}_{date}", so we can't use
    // the {uid} wildcard directly; match by checking the doc ID prefix instead.
    match /dailyQuests/{questDoc} {
      allow read: if isAuth() && (
        questDoc.matches(request.auth.uid + '_.+')
        || isAdmin()
        || isTeacher()
      );
      allow create: if isAuth()
        && request.resource.data.ownerUid == request.auth.uid
        && questDoc.matches(request.auth.uid + '_.+');
      allow update: if isAuth() && (
        questDoc.matches(request.auth.uid + '_.+')
        || isAdmin()
        || (
          isTeacher()
          && request.resource.data.ownerUid is string
          && questDoc.matches(request.resource.data.ownerUid + '_.+')
          && teacherMayTouchStudentDailyQuest(request.resource.data.ownerUid)
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quests'])
            || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['quests', 'ownerUid'])
          )
        )
      );
      allow delete: if isAdmin();
    }

    // Teacher-created quests — readable by any authenticated user (students need
    // to see quests assigned to them); only teachers/admins can create or modify.
    match /quests/{questId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isTeacher();
      allow update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    // Quest completion proofs — students create their own submissions;
    // teachers/admins can update (approve/reject) any submission.
    match /questCompletions/{completionId} {
      allow read: if isAuth() && (
        isAdmin() || isTeacher() ||
        resource.data.studentId == request.auth.uid
      );
      allow create: if isAuth()
        && request.resource.data.studentId == request.auth.uid;
      allow update: if isAdmin() || isTeacher();
      allow delete: if isAdmin();
    }

    // Shared voxel world — seeds + legacy customBlocks mirror; live block list syncs via RTDB `worldBlockEdits`.
    match /sharedWorlds/{worldId} {
      allow read: if isAuth();
      allow create, update: if isAuth();
      allow delete: if isAdmin();
    }
  }
}
